// Adaptive-first AI Tutor RBAC + Adaptive Learning schema
// Paste into https://dbdiagram.io/d to visualize.

Project adaptive_ai_tutor {
  database_type: 'PostgreSQL / SQL Server conceptual'
  Note: '''
  Hybrid C schema: runtime app tables + audit tables.
  Adaptive learning is core. Socratic is rule-based support layer.
  '''
}

Enum user_status {
  active
  invited
  disabled
}

Enum course_status {
  draft
  active
  archived
}

Enum course_role {
  student
  mentor
  admin
}

Enum membership_status {
  active
  removed
}

Enum publish_status {
  draft
  published
  archived
}

Enum embedding_status {
  pending
  indexed
  failed
}

Enum concept_status {
  active
  archived
}

Enum mastery_state {
  not_started
  weak
  learning
  mastered
}

Enum question_type {
  mcq
  short_answer
  code
  flashcard
}

Enum calibration_status {
  draft
  calibrating
  published
  retired
}

Enum grading_method {
  deterministic
  ai
  manual
}

Enum chat_mode {
  explain
  hint
  debug_code
  practice
  review_submission
}

Enum message_role {
  student
  assistant
  system
}

Enum policy_action {
  answer
  hint
  refuse
  redirect
  low_confidence
}

Enum feedback_target {
  message
  question
  citation
  quiz_attempt
}

Enum feedback_type {
  helpful
  unhelpful
  incorrect
  bad_citation
  unsafe
}

Enum signal_type {
  chat
  quiz
  hint
  review
  feedback
  guardrail
}

Enum policy_status {
  draft
  active
  retired
}

Enum decision_type {
  question
  concept
  review
  hint_style
}

Enum exploration_mode {
  explore
  exploit
  fallback
}

Enum mastery_source_type {
  quiz_attempt
  flashcard_review
  manual_adjustment
  diagnostic
}

Table app_users as users {
  id uuid [pk]
  email text [not null, unique]
  password_hash text
  full_name text [not null]
  status user_status [not null, default: 'active']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table app_roles as roles {
  id smallint [pk]
  code course_role [not null, unique]
  name text [not null]
}

Table app_user_roles as user_roles {
  user_id uuid [not null]
  role_id smallint [not null]
  created_at timestamptz [not null]

  indexes {
    (user_id, role_id) [pk]
  }
}

Table app_courses as courses {
  id uuid [pk]
  code text [not null, unique]
  title text [not null]
  status course_status [not null, default: 'draft']
  created_by uuid
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table app_course_members as course_members {
  course_id uuid [not null]
  user_id uuid [not null]
  role_code course_role [not null]
  status membership_status [not null, default: 'active']
  joined_at timestamptz [not null]

  indexes {
    (course_id, user_id, role_code) [pk]
    (user_id, course_id)
    (course_id, role_code)
  }
}

Table app_concepts as concepts {
  id uuid [pk]
  course_id uuid [not null]
  code text [not null]
  name text [not null]
  description text
  parent_concept_id uuid
  status concept_status [not null, default: 'active']
  created_at timestamptz [not null]

  indexes {
    (course_id, code) [unique]
    (course_id, status)
  }
}

Table app_course_materials as course_materials {
  id uuid [pk]
  course_id uuid [not null]
  title text [not null]
  source_type text [not null]
  storage_uri text [not null]
  published_status publish_status [not null, default: 'draft']
  uploaded_by uuid
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table app_material_chunks as material_chunks {
  id uuid [pk]
  material_id uuid [not null]
  course_id uuid [not null]
  concept_id uuid
  chunk_index integer [not null]
  page_number integer
  section_title text
  text_excerpt text [not null]
  embedding vector(1536) [note: 'pgvector - Supabase']
  embedding_status embedding_status [not null, default: 'pending']
  created_at timestamptz [not null]

  indexes {
    (material_id, chunk_index) [unique]
    (course_id, concept_id)
  }
}

Table app_student_concept_mastery as student_concept_mastery {
  student_id uuid [not null]
  course_id uuid [not null]
  concept_id uuid [not null]
  elo_score decimal [not null, default: 1200]
  bkt_mastery_probability decimal [not null, default: 0.25]
  mastery_state mastery_state [not null, default: 'not_started']
  weakness_flag boolean [not null, default: false]
  attempt_count integer [not null, default: 0]
  correct_count integer [not null, default: 0]
  last_practiced_at timestamptz
  updated_at timestamptz [not null]

  indexes {
    (student_id, course_id, concept_id) [pk]
    (student_id, course_id)
    (course_id, concept_id, mastery_state)
  }

  Note: 'Runtime source of truth for current adaptive state.'
}

Table app_questions as questions {
  id uuid [pk]
  course_id uuid [not null]
  concept_id uuid [not null]
  source_material_id uuid
  type question_type [not null]
  prompt text [not null]
  answer_key json [not null]
  difficulty_elo decimal [not null, default: 1200]
  calibration_status calibration_status [not null, default: 'draft']
  created_by uuid
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    (course_id, concept_id, calibration_status)
    (concept_id, difficulty_elo)
  }
}

Table app_question_hints as question_hints {
  id uuid [pk]
  question_id uuid [not null]
  level integer [not null]
  hint_text text [not null]

  indexes {
    (question_id, level) [unique]
  }

  Note: 'Rule-based / Socratic hint ladder. Support layer, not core mastery source.'
}

Table audit_adaptive_policies as adaptive_policies {
  id uuid [pk]
  name text [not null]
  version text [not null]
  status policy_status [not null, default: 'draft']
  config json [not null]
  created_at timestamptz [not null]

  indexes {
    (name, version) [unique]
  }
}

Table audit_adaptive_decisions as adaptive_decisions {
  id uuid [pk]
  policy_id uuid [not null]
  student_id uuid [not null]
  course_id uuid [not null]
  concept_id uuid
  decision_type decision_type [not null, default: 'question']
  selected_action_id uuid
  selected_action_type text [not null, default: 'question']
  candidate_action_ids json [not null]
  context_snapshot json [not null]
  model_snapshot json [not null]
  expected_reward decimal
  expected_success decimal
  exploration_mode exploration_mode [not null, default: 'exploit']
  reason_code text
  created_at timestamptz [not null]

  indexes {
    (student_id, created_at)
    (policy_id, created_at)
  }

  Note: 'Contextual bandit decision trace: context, candidates, selected action, model snapshot.'
}

Table app_quiz_attempts as quiz_attempts {
  id uuid [pk]
  student_id uuid [not null]
  course_id uuid [not null]
  question_id uuid [not null]
  concept_id uuid [not null]
  adaptive_decision_id uuid
  student_answer json [not null]
  is_correct boolean
  actual_score decimal [not null]
  expected_success decimal
  hint_count integer [not null, default: 0]
  used_ai_help boolean [not null, default: false]
  grading_method grading_method [not null, default: 'deterministic']
  submitted_at timestamptz [not null]

  indexes {
    (student_id, course_id, submitted_at)
    (question_id)
  }
}

Table audit_adaptive_rewards as adaptive_rewards {
  id uuid [pk]
  adaptive_decision_id uuid [not null]
  quiz_attempt_id uuid
  reward_value decimal [not null]
  reward_formula text [not null]
  observed_success decimal
  target_success decimal [not null, default: 0.75]
  reward_components json [not null]
  created_at timestamptz [not null]

  indexes {
    (adaptive_decision_id)
  }
}

Table audit_bkt_parameters as bkt_parameters {
  id uuid [pk]
  course_id uuid [not null]
  concept_id uuid [not null]
  prior_learned decimal [not null]
  transition_learn decimal [not null]
  guess decimal [not null]
  slip decimal [not null]
  version text [not null]
  status policy_status [not null, default: 'active']
  created_at timestamptz [not null]

  indexes {
    (concept_id, version) [unique]
  }
}

Table audit_mastery_events as mastery_events {
  id uuid [pk]
  student_id uuid [not null]
  course_id uuid [not null]
  concept_id uuid [not null]
  source_type mastery_source_type [not null]
  source_id uuid
  elo_before decimal [not null]
  elo_after decimal [not null]
  elo_delta decimal [not null]
  bkt_before decimal [not null]
  bkt_after decimal [not null]
  bkt_delta decimal [not null]
  state_before mastery_state [not null]
  state_after mastery_state [not null]
  parameters_snapshot json [not null]
  created_at timestamptz [not null]

  indexes {
    (student_id, concept_id, created_at)
  }

  Note: 'Append-only Elo + BKT state transition log.'
}

Table audit_question_elo_events as question_elo_events {
  id uuid [pk]
  question_id uuid [not null]
  quiz_attempt_id uuid [not null]
  difficulty_before decimal [not null]
  difficulty_after decimal [not null]
  difficulty_delta decimal [not null]
  parameters_snapshot json [not null]
  created_at timestamptz [not null]
}

Table app_chat_sessions as chat_sessions {
  id uuid [pk]
  student_id uuid [not null]
  course_id uuid [not null]
  mode chat_mode [not null]
  started_at timestamptz [not null]
  ended_at timestamptz
}

Table app_chat_messages as chat_messages {
  id uuid [pk]
  session_id uuid [not null]
  role message_role [not null]
  content text [not null]
  concept_id uuid
  rag_confidence decimal
  policy_action policy_action
  guardrail_flags json [not null]
  adaptive_context_snapshot json [not null]
  created_at timestamptz [not null]

  indexes {
    (session_id, created_at)
  }
}

Table app_message_citations as message_citations {
  message_id uuid [not null]
  chunk_id uuid [not null]
  rank integer [not null]
  quoted_excerpt text [not null]

  indexes {
    (message_id, chunk_id) [pk]
  }
}

Table app_feedback_events as feedback_events {
  id uuid [pk]
  user_id uuid [not null]
  course_id uuid [not null]
  target_type feedback_target [not null]
  target_id uuid [not null]
  feedback_type feedback_type [not null]
  comment text
  created_at timestamptz [not null]

  indexes {
    (course_id, created_at)
  }
}

Table app_learning_signals as learning_signals {
  id uuid [pk]
  student_id uuid
  course_id uuid [not null]
  concept_id uuid
  signal_type signal_type [not null]
  signal_value json [not null]
  created_at timestamptz [not null]

  indexes {
    (course_id, signal_type, created_at)
  }
}

Ref: user_roles.user_id > users.id [delete: cascade]
Ref: user_roles.role_id > roles.id

Ref: courses.created_by > users.id [delete: set null]
Ref: course_members.course_id > courses.id [delete: cascade]
Ref: course_members.user_id > users.id [delete: cascade]

Ref: concepts.course_id > courses.id [delete: cascade]
Ref: concepts.parent_concept_id > concepts.id [delete: set null]

Ref: course_materials.course_id > courses.id [delete: cascade]
Ref: course_materials.uploaded_by > users.id [delete: set null]

Ref: material_chunks.material_id > course_materials.id [delete: cascade]
Ref: material_chunks.course_id > courses.id [delete: cascade]
Ref: material_chunks.concept_id > concepts.id [delete: set null]

Ref: student_concept_mastery.student_id > users.id [delete: cascade]
Ref: student_concept_mastery.course_id > courses.id [delete: cascade]
Ref: student_concept_mastery.concept_id > concepts.id [delete: cascade]

Ref: questions.course_id > courses.id [delete: cascade]
Ref: questions.concept_id > concepts.id [delete: cascade]
Ref: questions.source_material_id > course_materials.id [delete: set null]
Ref: questions.created_by > users.id [delete: set null]
Ref: question_hints.question_id > questions.id [delete: cascade]

Ref: adaptive_policies.id < adaptive_decisions.policy_id
Ref: adaptive_decisions.student_id > users.id [delete: cascade]
Ref: adaptive_decisions.course_id > courses.id [delete: cascade]
Ref: adaptive_decisions.concept_id > concepts.id [delete: set null]

Ref: quiz_attempts.student_id > users.id [delete: cascade]
Ref: quiz_attempts.course_id > courses.id [delete: cascade]
Ref: quiz_attempts.question_id > questions.id [delete: cascade]
Ref: quiz_attempts.concept_id > concepts.id [delete: cascade]
Ref: quiz_attempts.adaptive_decision_id > adaptive_decisions.id [delete: set null]

Ref: adaptive_rewards.adaptive_decision_id > adaptive_decisions.id [delete: cascade]
Ref: adaptive_rewards.quiz_attempt_id > quiz_attempts.id [delete: set null]

Ref: bkt_parameters.course_id > courses.id [delete: cascade]
Ref: bkt_parameters.concept_id > concepts.id [delete: cascade]

Ref: mastery_events.student_id > users.id [delete: cascade]
Ref: mastery_events.course_id > courses.id [delete: cascade]
Ref: mastery_events.concept_id > concepts.id [delete: cascade]

Ref: question_elo_events.question_id > questions.id [delete: cascade]
Ref: question_elo_events.quiz_attempt_id > quiz_attempts.id [delete: cascade]

Ref: chat_sessions.student_id > users.id [delete: cascade]
Ref: chat_sessions.course_id > courses.id [delete: cascade]
Ref: chat_messages.session_id > chat_sessions.id [delete: cascade]
Ref: chat_messages.concept_id > concepts.id [delete: set null]
Ref: message_citations.message_id > chat_messages.id [delete: cascade]
Ref: message_citations.chunk_id > material_chunks.id [delete: cascade]

Ref: feedback_events.user_id > users.id [delete: cascade]
Ref: feedback_events.course_id > courses.id [delete: cascade]

Ref: learning_signals.student_id > users.id [delete: cascade]
Ref: learning_signals.course_id > courses.id [delete: cascade]
Ref: learning_signals.concept_id > concepts.id [delete: set null]
