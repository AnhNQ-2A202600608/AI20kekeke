# ============================================
# AI20K Project — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ---- LLM Configuration ----
OPENAI_API_KEY=
# Or use other providers:
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# For SQLite (development):
# DATABASE_URL=sqlite:///./data/app.db
SUPABASE_URL=https://your-project-ref.supabase.co
# Server-only backend key. Use sb_secret_... for new Supabase projects.
SUPABASE_SECRET_KEY=
# Deprecated one-release migration alias for backend only. Do not set public keys here.
SUPABASE_KEY=

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/chroma
# Or Pinecone:
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# ---- App Config ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_ALLOW_DEV_TOKENS=false

# ---- LangSmith (AI Logs — Deliverable #4) ----
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=ai20k-agent
LANGCHAIN_TRACING_V2=true

# ---- Braintrust Observability / Evals ----
BRAINTRUST_API_URL=
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_ID=
# Optional: UI base URL used to build trace detail links in the admin panel.
BRAINTRUST_APP_URL=

# ---- Logging ----
LOG_LEVEL=INFO

# ---- AI Hook Logging (provided by instructor) ----
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=f3p1dEOhD_z8qjjtbeCtb2t9ASMEliz-4juZfWe3ZPgCtPZp-LjWthBfeNU8d5dP
AI_LOG_DIR=.ai-log

# ---- Frontend (if separate) ----
# NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_DEMO_MODE=false


