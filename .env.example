# =============================================================================
# VAIC Universal Starter — Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME=vaic-universal-starter
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# --- Storage ---
STORAGE_PATH=./data
# PDF SGK lớn (>50MB) nên đặt trực tiếp vào data/ và chạy scripts/ingest_pdfs.py thay vì
# upload qua UI/API /files — cách đó vẫn bị giới hạn bởi MAX_UPLOAD_SIZE_MB.
MAX_UPLOAD_SIZE_MB=50

# --- Challenge workspace ---
# Use a slug under challenges/ or an absolute workspace path.
ACTIVE_CHALLENGE=

# --- OCR pipeline (scripts/ingest_pdfs.py, module `rag`) ---
# Thư mục chứa PDF SGK gốc + nơi ghi data/processed/. Mặc định là data/ ở ROOT repo
# (khác với STORAGE_PATH/backend/data dùng cho uploads/artifacts/runs của app) —
# xem scripts/project_tasks.py:clean_project, hai thư mục này tách biệt theo thiết kế.
SGK_DATA_DIR=./data
# Ngôn ngữ Tesseract dùng để OCR (cần cài traineddata tương ứng, vd vie.traineddata).
OCR_LANG=vie
# DPI khi render trang PDF thành ảnh trước khi OCR — cao hơn thì chính xác hơn nhưng chậm hơn.
OCR_DPI=300
# Ngưỡng số ký tự "sạch" tối thiểu/trang để coi text layer PDF là dùng được, dưới ngưỡng
# này (hoặc chỉ còn watermark) sẽ fallback sang OCR ảnh.
OCR_MIN_CHARS_PER_PAGE=40
# Đường dẫn tới binary tesseract nếu không có sẵn trên PATH (thường gặp trên Windows),
# ví dụ: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
# Chunking cho RAG vector index (TF-IDF nội bộ, không cần dịch vụ ngoài).
RAG_CHUNK_CHARS=1200
RAG_CHUNK_OVERLAP_CHARS=200
RAG_TOP_K=5
