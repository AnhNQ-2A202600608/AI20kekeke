# =============================================================================
# VAIC Universal Starter — Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME=vaic-universal-starter
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# --- Storage ---
STORAGE_PATH=./data
MAX_UPLOAD_SIZE_MB=50
