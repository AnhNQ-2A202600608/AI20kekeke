# =============================================================================
# VAIC AI Agent Starter Template — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- LLM Provider ---
# Supported: stub, openai, google
LLM_PROVIDER=stub
# Only needed when LLM_PROVIDER != stub
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# --- Database ---
# SQLite for development, PostgreSQL for production
DATABASE_URL=sqlite:///./data/vaic_agent.db
# DATABASE_URL=postgresql://user:password@localhost:5432/vaic_agent

# --- Session ---
SESSION_SECRET_KEY=change-me-to-a-random-secret-key
SESSION_MAX_AGE_SECONDS=3600
X