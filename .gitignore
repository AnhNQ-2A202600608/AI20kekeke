# ============================================================
# VAIC AI Agent Starter Template — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
ENV/

# --- Node.js ---
node_modules/
.next/
out/
.turbo/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Environment ---
.env
.env.local
.env.*.local

# --- Data / Database ---
# Keep raw PDFs and backend runtime storage local, but allow the small OCR output
# and local RAG index to be shared with teammates.
/backend/data/
/data/*
!/data/processed/
!/data/processed/**
!/data/rag_index/
!/data/rag_index/**
*.db
*.sqlite
*.sqlite3

# --- Logs ---
*.log
logs/

# --- Coverage ---
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- pytest ---
.pytest_cache/

# --- mypy ---
.mypy_cache/

# --- ruff ---
.ruff_cache/

# --- OS ---
Desktop.ini
ehthumbs.db
