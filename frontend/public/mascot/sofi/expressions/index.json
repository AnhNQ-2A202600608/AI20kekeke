{
  "version": 1,
  "description": "Sofi head expression avatar assets for small AI/chat UI.",
  "basePath": "/mascot/sofi/expressions",
  "runtimeFormat": "webp",
  "dimensions": "384x384 runtime WebP",
  "usageRules": [
    "Use WebP files for runtime UI.",
    "This folder intentionally indexes runtime WebP files only.",
    "Use these for avatars, small feedback badges, AI rail headers, and typing indicators.",
    "Do not scale images above their container; keep object-contain and fixed square dimensions.",
    "Prefer full-body mascot assets from /mascot/sofi for larger coach panels."
  ],
  "assets": [
    {
      "expression": "calm",
      "path": "/mascot/sofi/expressions/sofi-calm.webp",
      "description": "Neutral friendly Sofi face.",
      "bestFor": ["default AI message avatar", "calm assistant header", "neutral state"],
      "avoidFor": ["success celebration", "error warning"]
    },
    {
      "expression": "happy",
      "path": "/mascot/sofi/expressions/sofi-happy.webp",
      "description": "Open-mouth happy Sofi face.",
      "bestFor": ["welcome message", "assistant CTA", "positive chat avatar"],
      "avoidFor": ["wrong answer", "guardrail", "error state"]
    },
    {
      "expression": "thinking",
      "path": "/mascot/sofi/expressions/sofi-thinking.webp",
      "description": "Sofi thinking with hand near chin.",
      "bestFor": ["typing indicator", "hint generation", "question reflection"],
      "avoidFor": ["final success", "urgent error"]
    },
    {
      "expression": "surprised",
      "path": "/mascot/sofi/expressions/sofi-surprised.webp",
      "description": "Surprised Sofi face.",
      "bestFor": ["new discovery", "unexpected result", "attention callout"],
      "avoidFor": ["normal chat", "calm study state"]
    },
    {
      "expression": "wink",
      "path": "/mascot/sofi/expressions/sofi-wink.webp",
      "description": "Winking Sofi face.",
      "bestFor": ["light encouragement", "small tip", "friendly microcopy"],
      "avoidFor": ["serious warning", "academic integrity notice"]
    },
    {
      "expression": "worried",
      "path": "/mascot/sofi/expressions/sofi-worried.webp",
      "description": "Worried Sofi face.",
      "bestFor": ["wrong answer", "recoverable error", "low confidence", "guardrail"],
      "avoidFor": ["success", "celebration"]
    },
    {
      "expression": "thumbs-up",
      "path": "/mascot/sofi/expressions/sofi-thumbs-up.webp",
      "description": "Happy Sofi with thumbs up.",
      "bestFor": ["correct answer", "success badge", "approval feedback"],
      "avoidFor": ["wrong answer", "error state"]
    },
    {
      "expression": "laughing",
      "path": "/mascot/sofi/expressions/sofi-laughing.webp",
      "description": "Laughing Sofi with closed eyes.",
      "bestFor": ["celebration", "friendly completion", "delight moment"],
      "avoidFor": ["serious assessment", "warning"]
    }
  ]
}
