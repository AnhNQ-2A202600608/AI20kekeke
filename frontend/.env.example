# =============================================================================
# VAIC Universal Starter — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local to customize during development.
# NEVER commit raw configuration with real host secrets to VCS.
# =============================================================================

# Browser requests use the same-origin Next.js proxy.
NEXT_PUBLIC_API_URL=/api/v1

# Server-side proxy destination.
BACKEND_API_URL=http://localhost:8000/api/v1
